{
  "version": 2,
  "installCommand": "pnpm install --prod=false",
  "buildCommand": "pnpm build",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
